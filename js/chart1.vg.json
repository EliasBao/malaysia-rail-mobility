{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 400,

  "data": {
    "url": "data/ridership_ktmb_monthly.csv"
  },

  "params": [
    {
      "name": "legendHover",
      "select": {
        "type": "point",
        "fields": ["service"],
        "on": "mouseover",
        "clear": "mouseout"
      },
      "bind": "legend"
    }
  ],

  "mark": {
    "type": "line",
    "strokeWidth": 3,
    "point": {
      "filled": true,
      "size": 70
    }
  },

  "encoding": {

    "opacity": {
      "condition": {
        "param": "legendHover",
        "value": 1
      },
      "value": 0.15
    },

    "x": {
      "field": "date",
      "type": "temporal",
      "title": "Date"
    },

    "y": {
      "field": "ridership",
      "type": "quantitative",
      "title": "Monthly Ridership"
    },

    "color": {
      "field": "service",
      "type": "nominal",
      "title": "Rail Service",
      "scale": {
        "range": [
          "#81D8D0",
          "#708090",
          "#A7C7E7",
          "#002FA7",
          "#2F4F4F"
        ]
      }
    },

    "tooltip": [

      {
        "field": "service",
        "type": "nominal",
        "title": "Rail Service"
      },

      {
        "field": "date",
        "type": "temporal",
        "title": "Month",
        "format": "%B %Y"
      },

      {
        "field": "ridership",
        "type": "quantitative",
        "title": "Monthly Ridership",
        "format": ","
      }

    ]
  }
}