{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 430,

  "data": {
    "url": "../data/ridership_ktmb_monthly.csv"
  },

  "transform": [

    {
      "aggregate": [
        {
          "op": "min",
          "field": "ridership",
          "as": "min_ridership"
        },
        {
          "op": "max",
          "field": "ridership",
          "as": "max_ridership"
        }
      ],
      "groupby": ["service"]
    },

    {
      "calculate": "((datum.max_ridership - datum.min_ridership) / datum.min_ridership) * 100",
      "as": "growth_percentage"
    },

    {
      "calculate": "0",
      "as": "baseline"
    },

    {
      "calculate": "datum.growth_percentage >= 0 ? 'Positive Growth' : 'Negative Growth'",
      "as": "growth_direction"
    }

  ],

  "encoding": {

    "y": {
      "field": "service",
      "type": "nominal",
      "sort": {
        "field": "growth_percentage",
        "order": "descending"
      },
      "title": null,
      "axis": {
        "labelFontSize": 13
      }
    }

  },

  "layer": [

    {
      "mark": {
        "type": "rule",
        "strokeWidth": 3
      },

      "encoding": {

        "x": {
          "field": "baseline",
          "type": "quantitative"
        },

        "x2": {
          "field": "growth_percentage"
        },

        "color": {
          "field": "growth_direction",
          "type": "nominal",
          "scale": {
            "domain": [
              "Positive Growth",
              "Negative Growth"
            ],
            "range": [
              "#002FA7",
              "#708090"
            ]
          },
          "legend": {
            "title": "Growth Direction"
          }
        }
      }
    },

    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 180
      },

      "encoding": {

        "x": {
          "field": "growth_percentage",
          "type": "quantitative",
          "title": "Growth Percentage (%)",
          "axis": {
            "format": ".0f",
            "grid": true
          }
        },

        "color": {
          "field": "growth_direction",
          "type": "nominal",
          "scale": {
            "domain": [
              "Positive Growth",
              "Negative Growth"
            ],
            "range": [
              "#2E8B57",
              "#D95F5F"
            ]
          },
          "legend": null
        },

        "tooltip": [
          {
            "field": "service",
            "type": "nominal",
            "title": "Rail Service"
          },
          {
            "field": "growth_percentage",
            "type": "quantitative",
            "title": "Growth Percentage",
            "format": ".1f"
          }
        ]
      }
    },

    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 10,
        "fontSize": 11,
        "color": "#444"
      },

      "encoding": {

        "x": {
          "field": "growth_percentage",
          "type": "quantitative"
        },

        "text": {
          "field": "growth_percentage",
          "type": "quantitative",
          "format": ".1f"
        }
      }
    }

  ],

  "config": {

    "view": {
      "stroke": null
    },

    "axis": {
      "domain": false,
      "tickColor": "#999",
      "labelFontSize": 12,
      "titleFontSize": 14
    },

    "background": "white"
  }
}