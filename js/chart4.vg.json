{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 360,

  "data": {
    "url": "data/ridership_ktmb_monthly.csv"
  },

  "transform": [

    {
      "aggregate": [
        {
          "op": "min",
          "field": "ridership",
          "as": "min_ridership"
        },
        {
          "op": "max",
          "field": "ridership",
          "as": "max_ridership"
        }
      ],
      "groupby": ["service"]
    },

    {
      "calculate": "((datum.max_ridership - datum.min_ridership) / datum.min_ridership) * 100",
      "as": "growth_percentage"
    },

    {
      "calculate": "0",
      "as": "baseline"
    },

    {
      "calculate": "datum.growth_percentage >= 0 ? 'Positive Growth' : 'Negative Growth'",
      "as": "growth_direction"
    },
    {
      "calculate":
      "datum.service == 'komuter_utara' ? 'Komuter Utara' : datum.service == 'shuttle_tebrau' ? 'Shuttle Tebrau' : datum.service == 'ets' ? 'ETS' : datum.service == 'intercity' ? 'Intercity' : 'Komuter'",
      "as": "service_label"
    }

  ],

  "encoding": {

    "y": {
      "field": "service_label",
      "type": "nominal",
      "sort": {
        "field": "growth_percentage",
        "order": "descending"
      },
      "title": null,
      "axis": {
        "labelFontSize": 13
      }
    }

  },

  "layer": [
    {
      "data": {
        "values": [
          {
            "x": 0,
            "label": "0% Benchmark"
          }
        ]
      },

      "mark": {
        "type": "text",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#666666",
        "align": "left",
        "dx": 5,
        "dy": -160
      },

      "encoding": {
        "x": {
          "field": "x",
          "type": "quantitative"
        },

        "text": {
          "field": "label"
        }
      }
    },

    {
      "mark": {
        "type": "rule",
        "strokeWidth": 3
      },

      "encoding": {

        "x": {
          "field": "baseline",
          "type": "quantitative"
        },

        "x2": {
          "field": "growth_percentage"
        },

        "color": {
          "field": "growth_direction",
          "type": "nominal",
          "scale": {
            "domain": [
              "Positive Growth",
              "Negative Growth"
            ],
            "range": [
              "#002FA7",
              "#708090"
            ]
          },
          "legend": {
            "title": "Growth Direction",
            "titleFontSize": 15,
            "labelFontSize": 13,
            "symbolSize": 220
          }
        }
      }
    },

    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 180
      },

      "encoding": {

        "x": {
          "field": "growth_percentage",
          "type": "quantitative",
          "title": "Growth Percentage (%)",
          "axis": {
            "format": ".0f",
            "grid": true
          }
        },

        "color": {
          "field": "growth_direction",
          "type": "nominal",
          "scale": {
            "domain": [
              "Positive Growth",
              "Negative Growth"
            ],
            "range": [
              "#002FA7",
              "#708090"
            ]
          },
          "legend": null
        },

        "tooltip": [
          {
            "field": "service_label",
            "type": "nominal",
            "title": "Rail Service"
          },
          {
            "field": "growth_percentage",
            "type": "quantitative",
            "title": "Growth Percentage",
            "format": ".1f"
          }
        ]
      }
    },

    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dy": 12,
        "fontSize": 11,
        "color": "#444"
      },

      "encoding": {

        "x": {
          "field": "growth_percentage",
          "type": "quantitative"
        },


        "text": {
          "field": "growth_percentage",
          "type": "quantitative",
          "format": ".1f"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "service_label": "Shuttle Tebrau",
            "growth_percentage": 55.5,
            "note": "Only service with\npositive growth"
          }
        ]
      },

      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": -150,
        "dy": -15,
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#002FA7"
      },

      "encoding": {

        "x": {
          "field": "growth_percentage",
          "type": "quantitative"
        },

        "y": {
          "field": "service_label",
          "type": "nominal"
        },

        "text": {
          "field": "note"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "service_label": "ETS",
            "growth_percentage": -92.6,
            "note": "Largest ridership decline"
          }
        ]
      },

      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 15,
        "dy": -15,
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#555555"
      },

      "encoding": {

        "x": {
          "field": "growth_percentage",
          "type": "quantitative"
        },

        "y": {
          "field": "service_label",
          "type": "nominal"
        },

        "text": {
          "field": "note"
        }
      }
    }
    

  ],

  "config": {

    "view": {
      "stroke": null
    },

    "axis": {
      "domain": false,
      "tickColor": "#999",
      "labelFontSize": 12,
      "titleFontSize": 14
    },

    "background": "white"
  }
}