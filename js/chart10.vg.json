{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 520,
  "height": 520,

  "title": {
    "text": "Urban Rail Mobility Composition in 2019",
    "fontSize": 28,
    "fontWeight": "bold",
    "anchor": "middle",
    "dy": -10
  },

  "data": {
    "url": "data/ridership_headline.csv"
  },

  "transform": [

    {
      "fold": [
        "rail_lrt_ampang",
        "rail_mrt_kajang",
        "rail_lrt_kj",
        "rail_monorail"
      ],
      "as": ["service", "ridership"]
    },

    {
      "calculate": "substring(datum.date,0,4)",
      "as": "year"
    },

    {
      "filter": "datum.year == '2019'"
    },

    {
      "calculate":
      "datum.service == 'rail_lrt_ampang' ? 'LRT Ampang' : datum.service == 'rail_mrt_kajang' ? 'MRT Kajang' : datum.service == 'rail_lrt_kj' ? 'LRT Kelana Jaya' : 'Monorail'",
      "as": "service_clean"
    },

    {
      "aggregate": [
        {
          "op": "sum",
          "field": "ridership",
          "as": "total_ridership"
        }
      ],
      "groupby": ["service_clean"]
    }
  ],

  "mark": {
    "type": "arc",
    "innerRadius": 90,
    "outerRadius": 190,
    "stroke": "white",
    "strokeWidth": 1
  },

  "encoding": {

    "theta": {
      "field": "total_ridership",
      "type": "quantitative"
    },

    "color": {
      "field": "service_clean",
      "type": "nominal",

      "scale": {

        "domain": [
          "LRT Ampang",
          "MRT Kajang",
          "LRT Kelana Jaya",
          "Monorail"
        ],

        "range": [
          "#81D8D0",
          "#708090",
          "#A7C7E7",
          "#002FA7"
        ]
      },

      "legend": {
        "title": "Rail Service",
        "orient": "left",
        "labelFontSize": 16,
        "titleFontSize": 18,
        "symbolSize": 220
      }
    },

    "tooltip": [
      {
        "field": "service_clean",
        "title": "Rail Service"
      },
      {
        "field": "total_ridership",
        "title": "Ridership",
        "format": ",.0f"
      }
    ]
  },

  "view": {
    "stroke": null
  },

  "config": {
    "background": "#FFFFFF"
  }
}