{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 520,
  "height": 520,

  "data": {
    "url": "data/ridership_headline.csv"
  },

  "transform": [

    {
      "fold": [
        "rail_lrt_ampang",
        "rail_mrt_kajang",
        "rail_lrt_kj",
        "rail_monorail"
      ],
      "as": ["service", "ridership"]
    },

    {
      "calculate": "substring(datum.date,0,4)",
      "as": "year"
    },

    {
      "filter": "datum.year == '2019'"
    },

    {
      "calculate":
      "datum.service == 'rail_lrt_ampang' ? 'LRT Ampang' : datum.service == 'rail_mrt_kajang' ? 'MRT Kajang' : datum.service == 'rail_lrt_kj' ? 'LRT Kelana Jaya' : 'Monorail'",
      "as": "service_clean"
    },

    {
      "aggregate": [
        {
          "op": "sum",
          "field": "ridership",
          "as": "total_ridership"
        }
      ],
      "groupby": ["service_clean"]
    },

    {
      "joinaggregate": [
        {
          "op": "sum",
          "field": "total_ridership",
          "as": "grand_total"
        }
      ]
    },

    {
      "calculate":
      "datum.total_ridership / datum.grand_total",
      "as": "percentage"
    }
  ],

  "params": [
    {
      "name": "hover",
      "select": {
        "type": "point",
        "fields": ["service_clean"],
        "on": "mouseover"
      }
    }
  ],

  "mark": {
    "type": "arc",
    "innerRadius": 120,
    "outerRadius": 190,
    "cornerRadius": 8,
    "stroke": "white",
    "strokeWidth": 2
  },

  "encoding": {

    "theta": {
      "field": "total_ridership",
      "type": "quantitative"
    },

    "color": {
      "field": "service_clean",
      "type": "nominal",

      "scale": {

        "domain": [
          "LRT Ampang",
          "LRT Kelana Jaya",
          "MRT Kajang",
          "Monorail",
          "MRT Putrajaya",
          "Komuter",
          "Others"
        ],

        "range": [
          "#81D8D0",
          "#708090",
          "#A7C7E7",
          "#002FA7",
          "#2F4F4F",
          "#4682B4",
          "#C0C0C0"
        ]
      },

      "legend": {
        "title": "Rail Service",
        "orient": "left",
        "labelFontSize": 16,
        "titleFontSize": 18,
        "symbolSize": 220
      }
    },

    "opacity": {
      "condition": {
        "param": "hover",
        "value": 1
      },
      "value": 0.45
    },

    "radiusOffset": {
      "condition": {
        "param": "hover",
        "value": 12
      },
      "value": 0
    },

    "tooltip": [
      {
        "field": "service_clean",
        "title": "Rail Service"
      },
      {
        "field": "total_ridership",
        "title": "Ridership",
        "format": ",.0f"
      },
      {
        "field": "percentage",
        "title": "Share",
        "format": ".1%"
      }
    ]
  },

  "view": {
    "stroke": null
  },

  "config": {
    "background": "#FFFFFF"
  }
}