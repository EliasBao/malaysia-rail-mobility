{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 420,

  "data": {
    "url": "data/ridership_headline.csv"
  },

  "transform": [

    {
      "fold": [
        "rail_ets",
        "rail_intercity",
        "rail_komuter_utara",
        "rail_tebrau",
        "rail_komuter"
      ],
      "as": ["service", "ridership"]
    },

    {
      "calculate": "year(toDate(datum.date))",
      "as": "year"
    },

    {
      "filter": "datum.year == 2022 || datum.year == 2024"
    },

    {
      "aggregate": [
        {
          "op": "sum",
          "field": "ridership",
          "as": "total_ridership"
        }
      ],
      "groupby": ["service", "year"]
    },

    {
      "calculate": "datum.year == 2022 ? 'Early Recovery(2022)' : 'Post-Recovery(2024)'",
      "as": "pandemic_period"
    },
    {
      "filter": "datum.service != 'rail_komuter'"
    },
    {
      "calculate":
      "datum.service == 'rail_ets' ? 'ETS' : datum.service == 'rail_intercity' ? 'Intercity' : datum.service == 'rail_komuter_utara' ? 'Komuter Utara' : 'Shuttle Tebrau'",
      "as": "service_label"
    }

  ],

  "layer": [

    {
      "data": {
        "values": [
          {
            "threshold": 3000000
          }
        ]
      },

      "mark": {
        "type": "rule",
        "strokeDash": [8,8],
        "strokeWidth": 2,
        "color": "#888888"
      },

      "encoding": {
        "y": {
          "field": "threshold",
          "type": "quantitative"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "threshold": 3000000,
            "label": "High-demand service threshold"
          }
        ]
      },

      "mark": {
        "type": "text",
        "align": "left",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#666666",
        "dx": 250,
        "dy": -10
      },

      "encoding": {

        "x": {
          "value": 340
        },

        "y": {
          "field": "threshold",
          "type": "quantitative"
        },

        "text": {
          "field": "label"
        }
      }
    },

    {
      "mark": {
        "type": "rule",
        "strokeDash": [4,4],
        "color": "#D0D0D0",
        "strokeWidth": 1.5
      },

      "encoding": {

        "x": {
          "field": "pandemic_period",
          "type": "ordinal"
        }
      }
    },

    

    {
      "mark": {
        "type": "line",
        "strokeWidth": 3,
        "point": {
          "filled": true,
          "size": 110
        }
      },

      "encoding": {

        "x": {
          "field": "pandemic_period",
          "type": "ordinal",
          "title": null,

          "scale": {
            "domain": [
              "Early Recovery(2022)",
              "Post-Recovery(2024)"
            ]
          },

          "axis": {
            "labelAngle": 0,
            "labelFontSize": 13
          }
        },

        "y": {
          "field": "total_ridership",
          "type": "quantitative",
          "title": "Total Annual Ridership",

          "axis": {
            "format": "~s",
            "grid": true
          }
        },

        "detail": {
          "field": "service"
        },

        "color": {
          "field": "service_label",
          "type": "nominal",
          "title": "Rail Service",
          "scale": {
            "domain": [
              "ETS",
              "Intercity",
              "Komuter Utara",
              "Shuttle Tebrau"
            ],
            "range": [
              "#81D8D0",
              "#708090",
              "#002FA7",
              "#2F4F4F"
            ]
          }
        },

        "tooltip": [
          {
            "field": "service_label",
            "type": "nominal",
            "title": "Rail Service"
          },

          {
            "field": "pandemic_period",
            "type": "nominal",
            "title": "Recovery Stage"
          },

          {
            "field": "total_ridership",
            "type": "quantitative",
            "title": "Total Ridership",
            "format": ","
          }
        ]
      }
    },

    {
      "transform": [
        {
          "filter": "datum.pandemic_period == 'Post-Recovery'"
        }
      ],

      "mark": {
        "type": "text",
        "align": "left",
        "dx": 10,
        "fontSize": 12,
        "fontWeight": "bold"
      },

      "encoding": {

        "x": {
          "field": "pandemic_period",
          "type": "ordinal"
        },

        "y": {
          "field": "total_ridership",
          "type": "quantitative"
        },

        "text": {
          "field": "service_label"
        },

        "color": {
          "field": "service_label",
          "type": "nominal"
        }
      }
    }

  ],

  "config": {

    "view": {
      "stroke": null
    },

    "axis": {
      "domain": false,
      "tickColor": "#999",
      "labelFontSize": 12,
      "titleFontSize": 14
    },

    "background": "white"
  }
}