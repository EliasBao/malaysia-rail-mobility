{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 420,

  "title": {
    "text": "Rail Service Composition Evolution",
    "subtitle": "How Malaysia's railway mobility composition evolved over time",
    "anchor": "start",
    "fontSize": 22,
    "subtitleFontSize": 13
  },

  "data": {
    "url": "../data/ridership_ktmb_monthly.csv"
  },

  "params": [
    {
      "name": "hover",
      "select": {
        "type": "point",
        "fields": ["service"],
        "on": "mouseover"
      }
    }
  ],

  "mark": {
    "type": "area",
    "interpolate": "monotone",
    "opacity": 0.9
  },

  "encoding": {

    "x": {
      "field": "date",
      "timeUnit": "yearmonth",
      "type": "temporal",
      "title": "Date",
      "axis": {
        "format": "%Y",
        "labelAngle": 0,
        "grid": false
      }
    },

    "y": {
      "aggregate": "sum",
      "field": "ridership",
      "stack": "center",
      "title": "Ridership Composition",
      "axis": {
        "grid": false
      }
    },

    "color": {
      "field": "service",
      "type": "nominal",
      "title": "Rail Service",
      "legend": {
        "orient": "right"
      }
    },

    "opacity": {
      "condition": {
        "param": "hover",
        "value": 1
      },
      "value": 0.25
    },

    "tooltip": [
      {
        "field": "date",
        "type": "temporal",
        "title": "Date"
      },
      {
        "field": "service",
        "type": "nominal",
        "title": "Rail Service"
      },
      {
        "aggregate": "sum",
        "field": "ridership",
        "type": "quantitative",
        "title": "Ridership",
        "format": ","
      }
    ]
  },

  "config": {
    "view": {
      "stroke": null
    },

    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 14,
      "domain": false,
      "tickColor": "#999"
    },

    "legend": {
      "labelFontSize": 12,
      "titleFontSize": 13
    }
  }
}