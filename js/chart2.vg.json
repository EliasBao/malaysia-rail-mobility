{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 420,

  "data": {
    "url": "data/ridership_ktmb_monthly.csv"
  },

  "params": [
    {
      "name": "legendHover",
      "select": {
        "type": "point",
        "fields": ["service"],
        "on": "mouseover",
        "clear": "mouseout"
      },
      "bind": "legend"
    },

    {
      "name": "YearFilter",
      "value": 2026,
      "bind": {
        "input": "range",
        "min": 2020,
        "max": 2026,
        "step": 1,
        "name": "Year: "
      }
    }
  ],

  "transform": [
    {
      "filter":
      "year(datum.date) <= YearFilter"
    }
  ],

  "mark": {
    "type": "area",
    "interpolate": "monotone",
    "opacity": 0.9
  },

  "encoding": {

    "x": {
      "field": "date",
      "timeUnit": "yearmonth",
      "type": "temporal",
      "title": "Month",
      "axis": {
        "format": "%b %Y",
        "labelAngle": 0,
        "grid": false
      }
    },

    "y": {
      "aggregate": "sum",
      "field": "ridership",
      "stack": "center",
      "title": "Ridership Composition",
      "axis": {
        "grid": false
      }
    },

    "color": {
      "field": "service",
      "type": "nominal",
      "title": "Rail Service",
      "scale": {
        "range": [
          "#81D8D0",
          "#708090",
          "#A7C7E7",
          "#002FA7",
          "#2F4F4F"
        ]
      },
      "legend": null
    },

    "opacity": {
      "condition": {
        "param": "legendHover",
        "value": 1
      },
      "value": 0.18
    },

    "tooltip": [
      {
        "field": "date",
        "type": "temporal",
        "title": "Month",
        "format": "%B %Y"
      },
      {
        "field": "service",
        "type": "nominal",
        "title": "Rail Service"
      },
      {
        "aggregate": "sum",
        "field": "ridership",
        "type": "quantitative",
        "title": "Ridership",
        "format": ","
      }
    ]
  },

  "config": {
    "view": {
      "stroke": null
    },

    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 14,
      "domain": false,
      "tickColor": "#999"
    },

    "legend": {
      "labelFontSize": 12,
      "titleFontSize": 13
    }
  }
}