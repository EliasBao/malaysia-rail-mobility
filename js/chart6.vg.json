{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 380,

  "data": {
    "url": "data/ridership_ktmb_monthly.csv"
  },

  "params": [

    {
      "name": "YearFilter",
      "value": 2026,

      "bind": {
        "input": "range",
        "min": 2021,
        "max": 2026,
        "step": 1,
        "name": "Year: "
      }
    }

  ],

  "transform": [

    {
      "filter":
      "year(datum.date) <= YearFilter"
    }

  ],

  "encoding": {

    "x": {
      "field": "date",
      "type": "temporal",
      "title": "Month",
      "axis": {
        "format": "%b %Y",
        "labelAngle": 0,
        "grid": false
      }
    },

    "y": {
      "aggregate": "sum",
      "field": "ridership",
      "type": "quantitative",
      "title": "Monthly Ridership",
      "axis": {
        "format": "~s",
        "grid": true
      }
    },

    "tooltip": [
      {
        "field": "date",
        "type": "temporal",
        "title": "Date"
      },
      {
        "aggregate": "sum",
        "field": "ridership",
        "type": "quantitative",
        "title": "Ridership",
        "format": ","
      }
    ]
  },

  "layer": [

    {
      "mark": {
        "type": "area",
        "opacity": 0.28,
        "color": "#4C78A8"
      }
    },

    {
      "mark": {
        "type": "line",
        "strokeWidth": 3,
        "color": "#2F5D8C"
      }
    },

    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 45,
        "color": "#2F5D8C"
      }
    },

    {
      "data": {
        "values": [
          {
            "event_date": "2023-09-01"
          }
        ]
      },

      "mark": {
        "type": "rule",
        "color": "#7A7A7A",
        "strokeWidth": 2,
        "strokeDash": [8,8]
      },

      "encoding": {
        "x": {
          "field": "event_date",
          "type": "temporal"
        }
      }
    },

    {
      "data": {
        "values": [
          {
            "event_date": "2023-09-01",
            "ridership": 2200000,
            "label": "2023 Sep-Oct"
          }
        ]
      },

      "mark": {
        "type": "text",
        "fontSize": 18,
        "fontWeight": "bold",
        "color": "#333333",
        "align": "right",
        "baseline": "bottom",
        "dx": -60,
        "dy": -10
      },

      "encoding": {
        "x": {
          "field": "event_date",
          "type": "temporal"
        },

        "y": {
          "field": "ridership",
          "type": "quantitative"
        },

        "text": {
          "field": "label"
        }
      }
    },

    {
      "data": {
        "values": [
          {
            "event_date": "2023-09-01",
            "ridership": 2050000,
            "label": "Post-pandemic recovery\nand mobility normalization"
          }
        ]
      },

      "mark": {
        "type": "text",
        "fontSize": 12,
        "color": "#444444",
        "align": "right",
        "lineBreak": "\n",
        "dx": -65,
        "dy": -20
      },

      "encoding": {
        "x": {
          "field": "event_date",
          "type": "temporal"
        },

        "y": {
          "field": "ridership",
          "type": "quantitative"
        },

        "text": {
          "field": "label"
        }
      }
    },

    {
      "data": {
        "values": [
          {
            "x1": "2023-06-01",
            "y1": 2050000,
            "x2": "2023-08-20",
            "y2": 1800000
          }
        ]
      },

      "mark": {
        "type": "rule",
        "strokeWidth": 2,
        "color": "#666666"
      },

      "encoding": {
        "x": {
          "field": "x1",
          "type": "temporal"
        },

        "y": {
          "field": "y1",
          "type": "quantitative"
        },

        "x2": {
          "field": "x2"
        },

        "y2": {
          "field": "y2"
        }
      }
    }

  ],

  "config": {

    "view": {
      "stroke": null
    },

    "axis": {
      "domain": false,
      "tickColor": "#999",
      "labelFontSize": 12,
      "titleFontSize": 14
    },

    "background": "white"
  }
}