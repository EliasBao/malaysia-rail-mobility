{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 380,

  "title": {
    "text": "Malaysia Rail Transfer Flow Structure",
    "fontSize": 28,
    "fontWeight": "bold",
    "anchor": "middle",
    "dy": -12
  },

  "data": {
    "url": "data/corridor_final.csv"
  },

  "transform": [

    {
      "calculate":
      "datum.line == 'LRT Kelana Jaya Line' ? 1 : 2",
      "as": "line_level"
    }

  ],

  "layer": [

    {
      "mark": {
        "type": "line",
        "strokeWidth": 12,
        "opacity": 0.28,
        "strokeCap": "round"
      },

      "encoding": {

        "x": {
          "field": "x_position",
          "type": "quantitative",
          "title": null,
          "axis": null
        },

        "y": {
          "field": "line_level",
          "type": "ordinal",
          "title": null,
          "axis": null
        },

        "detail": {
          "field": "line"
        },

        "color": {
          "field": "line",
          "type": "nominal",
          "title": "Rail System",

          "scale": {
            "domain": [
              "LRT Kelana Jaya Line",
              "MRT Kajang Line"
            ],

            "range": [
              "#d62828",
              "#E9C46A"
            ]
          }
        }
      }
    },

    {
      "params": [
        {
          "name": "hover",
          "select": {
            "type": "point",
            "on": "mouseover",
            "clear": "mouseout"
          }
        }
      ],

      "mark": {
        "type": "circle",
        "stroke": "white",
        "strokeWidth": 2
      },

      "encoding": {

        "x": {
          "field": "x_position",
          "type": "quantitative"
        },

        "y": {
          "field": "line_level",
          "type": "ordinal"
        },

        "size": {
          "condition": {
            "param": "hover",

            "field": "importance",

            "scale": {
              "domain": [1, 3],
              "range": [320, 1500]
            }
          },

          "field": "importance",
          "type": "quantitative",
          "title": "Station Importance",

          "scale": {
            "domain": [1, 3],
            "range": [180, 900]
          },

          "legend": {
            "values": [1, 2, 3]
          }
        },

        "opacity": {
          "condition": {
            "param": "hover",
            "value": 1
          },
          "value": 0.2
        },

        "color": {
          "field": "line",
          "type": "nominal",
          "legend": null,

          "scale": {
            "domain": [
              "LRT Kelana Jaya Line",
              "MRT Kajang Line"
            ],

            "range": [
              "#d62828",
              "#E9C46A"
            ]
          }
        },

        "tooltip": [

          {
            "field": "station",
            "title": "Station"
          },

          {
            "field": "line",
            "title": "Rail Line"
          },

          {
            "field": "importance",
            "title": "Connectivity Importance"
          }

        ]
      }
    },

    {
      "transform": [

        {
          "filter": "datum.label_show == 1"
        }

      ],

      "mark": {
        "type": "text",
        "fontSize": 14,
        "fontWeight": "bold",
        "color": "#222",
        "angle": -20,
        "baseline": "bottom",
        "align": "left",
        "dx": 0,
        "dy": -14
      },

      "encoding": {

        "x": {
          "field": "x_position",
          "type": "quantitative"
        },

        "y": {
          "field": "line_level",
          "type": "ordinal"
        },

        

        "text": {
          "field": "station"
        }
      }
    },

    {
      "mark": {
        "type": "text",
        "fontSize": 20,
        "fontWeight": "bold",
        "color": "#444"
      },

      "encoding": {

        "x": {
          "value": 90
        },

        "y": {
          "value": 30
        },

        "text": {
          "value": "LRT Kelana Jaya Line"
        }
      }
    },

    {
      "mark": {
        "type": "text",
        "fontSize": 20,
        "fontWeight": "bold",
        "color": "#444"
      },

      "encoding": {

        "x": {
          "value": 70
        },

        "y": {
          "value": 200
        },

        "text": {
          "value": "MRT Kajang Line"
        }
      }
    }

  ],

  "config": {

    "background": "white",

    "view": {
      "stroke": null
    },

    "legend": {
      "orient": "right",
      "labelFontSize": 13,
      "titleFontSize": 14
    }
  }
}